-- FlowLang Test Module
-- A utility module for testing the package manager

-- Public utility functions
@export cast Spell greet(name) -> Silk {
    return "Hello, " + name + "! 👋"
}

@export cast Spell add(a, b) -> Ember {
    return a + b
}

@export cast Spell multiply(a, b) -> Ember {
    return a * b
}

@export seal VERSION = "1.0.0"
@export seal NAME = "FlowLang Test Module"

shout("📦 Module loaded: " + NAME + " v" + VERSION)
